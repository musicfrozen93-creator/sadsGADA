# ─────────────────────────────────────────────
# AI Crypto Futures Trading Bot — Environment
# ─────────────────────────────────────────────

# Binance Futures API
# Get from: https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here

# Set to "false" for mainnet trading (REAL MONEY)
# Keep "true" for testnet (paper trading)
BINANCE_TESTNET=true

# OpenAI API
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# Telegram Bot
# 1. Create bot via @BotFather on Telegram
# 2. Get your chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Account Settings
# Set to your actual starting USDT balance
ACCOUNT_BALANCE=20.0

# Minimum AI confidence to trade (default 70)
MIN_CONFIDENCE=70
